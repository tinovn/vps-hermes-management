# hermes-vps environment — copy to /opt/hermes/.env
# After changes: systemctl restart hermes-gateway hermes-dashboard hermes-mgmt caddy

# --- Core ---
HERMES_HOME=/opt/hermes/.hermes
HERMES_VPS_VERSION=0.1.0
HERMES_DROPLET_IP=127.0.0.1
DOMAIN=localhost
CADDY_TLS=tls internal

# --- Ports ---
HERMES_DASHBOARD_PORT=9119
HERMES_MGMT_PORT=9997

# --- Auth (regenerate with: openssl rand -hex 32) ---
HERMES_GATEWAY_TOKEN=
HERMES_MGMT_API_KEY=
HERMES_MGMT_SESSION_SECRET=

# --- Login (for /login web page — optional) ---
# Set via: curl -X POST -H "Authorization: Bearer $KEY" \
#   -H "Content-Type: application/json" \
#   -d '{"username":"admin","password":"..."}' \
#   http://localhost:9997/api/auth/create-user
# HERMES_LOGIN_USER=
# HERMES_LOGIN_HASH=

# --- Provider API keys (fill what you use) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# NOUS_API_KEY=
# OPENROUTER_API_KEY=
# HUGGINGFACE_TOKEN=
# ZAI_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=
# MIMO_API_KEY=

# --- Messaging platform tokens ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_HOME_CHANNEL=
# DISCORD_BOT_TOKEN=
# DISCORD_HOME_CHANNEL=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SIGNAL_ACCOUNT=
# SIGNAL_HTTP_URL=
# SIGNAL_ALLOWED_USERS=
# WHATSAPP_MODE=
# WHATSAPP_ENABLED=

# --- Zalo personal plugin (zalo-personal, installed by default) ---
# Unofficial Zalo Web API via zca-js Node sidecar. USE A SECONDARY NUMBER —
# bulk friend/message actions risk account bans. First run needs QR login:
#   curl -X POST http://127.0.0.1:3838/login/qr  &&  open http://127.0.0.1:3838/qr.png
# Required: owner Zalo UID (message bot once, grep gateway log for from_uid=).
ZALO_PERSONAL_OWNER_UID=
ZALO_PERSONAL_SIDECAR_PORT=3838
ZALO_PERSONAL_SESSION_DIR=/opt/data/zalo
# Anyone who messages the bot can chat without per-user approval. Set false to
# require approving each new user (owner is always allowed).
ZALO_PERSONAL_ALLOW_ALL_USERS=true
# ZALO_PERSONAL_ALLOWED_USERS=
# ZALO_PERSONAL_PROXY=
# ZALO_OWNER_NICKNAME=sếp
# ZALO_OWNER_NAME=
# GOOGLE_TOKEN_PATH=
# ZALO_PERSONAL_HOME_THREAD=
